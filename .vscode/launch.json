{
    "version": "0.2.0",
    "configurations": [
        {
            "cwd": "${workspaceFolder}",
            "executable": "${command:cmake.launchTargetPath}",
            "name": "Debug SWDP",
            "request": "launch",
            "type": "cortex-debug",
            "runToEntryPoint": "main",
            "showDevDebugOutput": "none",
            "servertype": "stlink"
        },

        {
            "cwd": "${workspaceFolder}",
            "executable": "${command:cmake.launchTargetPath}",
            "name": "Attach to Main Board",
            "request": "attach",
            "type": "cortex-debug",
            "runToEntryPoint": "main",
            "showDevDebugOutput": "none",
            "servertype": "stlink"
        }
    ]
}
 